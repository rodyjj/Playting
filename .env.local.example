NEXT_PUBLIC_SUPABASE_ANON_KEY=

# https://www.themoviedb.org/settings/api 에서 무료로 발급 (v3 auth "API Key")
TMDB_API_KEY=

# https://aistudio.google.com/apikey 에서 무료로 발급 (AI 코스 추천 생성용)
