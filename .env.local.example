NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# https://www.themoviedb.org/settings/api 에서 무료로 발급 (v3 auth "API Key")
TMDB_API_KEY=

# https://aistudio.google.com/apikey 에서 무료로 발급 (AI 코스 추천 생성용)
GEMINI_API_KEY=

# 위 GEMINI_API_KEY 대신 Vertex AI 경로를 쓰려면 아래 3개를 채우세요 (Cloud Billing
# 크레딧이 적용되는 쪽 — AI Studio API 키의 무료 티어 한도와는 별개 과금 체계).
# 셋 다 채워지면 이쪽이 우선 사용됩니다.
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_VERTEX_CREDENTIALS=

# https://console.cloud.google.com 에서 무료로 발급 (예고편/보조 영상 검색용)
# "YouTube Data API v3"를 활성화한 뒤 APIs & Services > Credentials 에서 API 키 생성
# search.list는 프로젝트당 하루 100회로 따로 제한되어 있어 실사용 트래픽에 금방
# 소진됩니다 — 여러 프로젝트에서 키를 발급받아 쉼표로 이어 붙이면(key1,key2,key3)
# 하나가 쿼터를 다 쓸 때마다 자동으로 다음 키로 넘어갑니다.
YOUTUBE_API_KEY=

# [임시] 정식 오픈 전까지만 쓰는 타임코스 쿼터 절약 장치 — 08:00~22:00(KST) 외에는
# YouTube/Gemini 호출을 아예 안 함. 그 시간에도 직접 개발/테스트하려면 1로 설정.
# 정식 오픈 후에는 이 줄과 src/lib/time-course.ts의 isTimeCourseQuietHours를 지워도 됨.
TIME_COURSE_FORCE_LIVE=
